<section class="diari-hero-clean">
  <div class="diari-hero-clean__inner">
    <p class="diari-hero-clean__eyebrow">Diari 1€</p>

    <h1>Gjithçka për shtëpinë dhe përditshmërinë tuaj</h1>

    <p class="diari-hero-clean__text">
      Kozmetikë, tekstil, pajisje shtëpie, lodra, vegla pune, artikuj shkollorë,
      bizhuteri dhe shumë më tepër — të gjitha në një vend.
    </p>

    <div class="diari-hero-clean__buttons">
      <a href="/collections/all" class="diari-hero-btn diari-hero-btn--primary">
        Shiko produktet
      </a>

      <a href="/collections" class="diari-hero-btn diari-hero-btn--secondary">
        Shiko kategoritë
      </a>
    </div>
  </div>
</section>

<style>
  .diari-hero-clean {
    min-height: 520px;
    padding: 80px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.18), transparent 30%),
      linear-gradient(135deg, #cc0000 0%, #9f0000 100%);
    color: #ffffff;
    text-align: center;
    overflow: hidden;
  }

  .diari-hero-clean__inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .diari-hero-clean__eyebrow {
    display: inline-block;
    margin: 0 0 16px;
    padding: 8px 18px;
    border: 1px solid rgba(255, 255, 255, 0.45);
    border-radius: 999px;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: 0.4px;
  }

  .diari-hero-clean h1 {
    margin: 0;
    font-size: clamp(38px, 6vw, 72px);
    line-height: 1.05;
    font-weight: 900;
    color: #ffffff;
  }

  .diari-hero-clean__text {
    max-width: 760px;
    margin: 24px auto 34px;
    font-size: clamp(17px, 2vw, 21px);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.95);
  }

  .diari-hero-clean__buttons {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .diari-hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 180px;
    padding: 15px 26px;
    border-radius: 10px;
    font-weight: 800;
    text-decoration: none;
    transition: 0.2s ease;
  }

  .diari-hero-btn--primary {
    background: #ffffff;
    color: #cc0000;
  }

  .diari-hero-btn--secondary {
    background: transparent;
    color: #ffffff;
    border: 2px solid #ffffff;
  }

  .diari-hero-btn:hover {
    transform: translateY(-2px);
    opacity: 0.92;
  }

  @media (max-width: 600px) {
    .diari-hero-clean {
      min-height: 480px;
      padding: 65px 18px;
    }

    .diari-hero-btn {
      width: 100%;
      max-width: 320px;
    }
  }
</style>

{% schema %}
{
  "name": "Diari Hero",
  "settings": [],
  "presets": [
    {
      "name": "Diari Hero"
    }
  ]
}
{% endschema %}