<section class="diari-trust-bar">
  <div class="diari-trust-item">
    <span>💶</span>
    <h3>Çmime të volitshme</h3>
    <p>Produkte praktike për çdo buxhet.</p>
  </div>

  <div class="diari-trust-item">
    <span>🛍️</span>
    <h3>Shumëllojshmëri</h3>
    <p>Kategori të ndryshme në një vend.</p>
  </div>

  <div class="diari-trust-item">
    <span>🏠</span>
    <h3>Për shtëpi & përditshmëri</h3>
    <p>Gjithçka që ju duhet çdo ditë.</p>
  </div>

  <div class="diari-trust-item">
    <span>🤝</span>
    <h3>Shërbim i kujdesshëm</h3>
    <p>Jemi këtu për t’ju ndihmuar.</p>
  </div>
</section>

<style>
  .diari-trust-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    background: #cc0000;
    color: #ffffff;
    padding: 34px 6%;
  }

  .diari-trust-item {
    text-align: center;
    padding: 10px 22px;
    border-right: 1px solid rgba(255, 255, 255, 0.25);
  }

  .diari-trust-item:last-child {
    border-right: none;
  }

  .diari-trust-item span {
    display: block;
    font-size: 30px;
    margin-bottom: 10px;
  }

  .diari-trust-item h3 {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 800;
    color: #ffffff;
  }

  .diari-trust-item p {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 900px) {
    .diari-trust-bar {
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }

    .diari-trust-item {
      border-right: none;
    }
  }

  @media (max-width: 520px) {
    .diari-trust-bar {
      grid-template-columns: 1fr;
      padding: 32px 18px;
    }
  }
</style>

{% schema %}
{
  "name": "Diari Trust Bar",
  "settings": [],
  "presets": [
    {
      "name": "Diari Trust Bar"
    }
  ]
}
{% endschema %}